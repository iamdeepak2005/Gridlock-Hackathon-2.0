# ─────────────────────────────────────────────────────────────
#  TRINETRA AI — Root Environment Variables
#  Copy this to .env and fill in your values
#  Used by docker-compose.yml
# ─────────────────────────────────────────────────────────────

# Google Gemini API Key (required for AI Copilot feature)
GEMINI_API_KEY=your_gemini_api_key_here

# Frontend API URL (where the browser connects to the backend)
# For local Docker: http://localhost:8000
# For production: https://your-backend-domain.com
NEXT_PUBLIC_API_URL=http://localhost:8000

# PostgreSQL credentials (used by docker-compose)
POSTGRES_DB=trinetra_db
POSTGRES_USER=trinetra
POSTGRES_PASSWORD=trinetra_pass
