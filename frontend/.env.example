# ─────────────────────────────────────────────────────────────
#  TRINETRA AI — Frontend Environment Variables
#  Copy this to .env.local and fill in your values
# ─────────────────────────────────────────────────────────────

# Backend API URL (used by the frontend to call backend endpoints)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Google Gemini API Key (used by Genkit AI flows on the server side)
GEMINI_API_KEY=your_gemini_api_key_here
