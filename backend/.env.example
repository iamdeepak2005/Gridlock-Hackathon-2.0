# ─────────────────────────────────────────────────────────────
#  TRINETRA AI — Backend Environment Variables
#  Copy this to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# Database (PostgreSQL for production, SQLite for local dev)
DATABASE_URL=postgresql://trinetra:trinetra_pass@localhost:5432/trinetra_db
# DATABASE_URL=sqlite:///./trinetra.db   # Uncomment for local SQLite dev

# Application
APP_ENV=development
APP_DEBUG=true

# ML Model paths (relative to backend/ directory)
MODEL_DIR=./trained_models
DATA_PATH=./data/events.csv

# OSMnx cache directory
OSMNX_CACHE_DIR=./osmnx_cache

# Google Gemini API Key (required for AI Copilot feature)
GEMINI_API_KEY=your_gemini_api_key_here
